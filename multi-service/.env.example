# Cloudflare credentials for DNS + Let's Encrypt (required)
# Copy this file to .env and fill in your values (never commit .env)
CF_API_TOKEN=your_cloudflare_api_token_here
CF_EMAIL=you@example.com

# Required on macOS and Windows — set to your machine's LAN IP (e.g. 192.168.1.42)
# On Linux, leave this unset — dynamoip auto-detects it.
# LAN_IP=
